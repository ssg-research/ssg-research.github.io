---
import BaseLayout from "../layouts/BaseLayout.astro";
---

{
  /*
   * Stage 2 demo harness. This sits at "/", so it exercises the home-page
   * masthead (brand hidden) and the "Secure Systems Group" document title.
   * The shared chrome — masthead nav, dark-mode toggle, footer — comes from
   * BaseLayout. Real page content replaces this in Stage 3.
   */
}
<BaseLayout>
  <h1>Layout &amp; design system</h1>
  <p>
    Stage 2 wires the Stage 1 tokens into the shared <code>BaseLayout</code>:
    masthead with primary nav and the dark-mode toggle, this centred content
    column, and the footer below. Toggle the theme (top right) — every colour
    re-resolves from <code>tokens.css</code>. The swatches confirm the semantic
    roles still resolve inside the real layout.
  </p>

  <h2>Semantic colour roles</h2>
  <div class="swatches">
    <div class="swatch" style="background: var(--color-bg-default)">
      bg-default
    </div>
    <div class="swatch" style="background: var(--color-bg-muted)">bg-muted</div>
    <div class="swatch" style="background: var(--color-surface)">surface</div>
    <div class="swatch on-accent" style="background: var(--color-theme)">
      theme
    </div>
    <div class="swatch on-accent" style="background: var(--color-accent-1)">
      accent-1 · MLSec
    </div>
    <div class="swatch on-accent" style="background: var(--color-accent-2)">
      accent-2 · PlatSec
    </div>
    <div class="swatch on-accent" style="background: var(--color-accent-3)">
      accent-3 · Other
    </div>
  </div>

  <p>
    Body copy with a <a href="#">link in the theme colour</a> and some
    <code>inline code</code> on a muted surface.
  </p>
</BaseLayout>

<style>
  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(8rem, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .swatch {
    padding: var(--space-4);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-family: var(--font-mono);
    color: var(--color-text-primary);
  }

  .swatch.on-accent {
    color: var(--color-white);
    border-color: transparent;
  }
</style>
