---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../constants/site";
import { wikiPermalink, wikiTitle } from "../lib/wiki";
import Publications from "../components/Publications.astro";

type ContentEntry =
  | CollectionEntry<"pages">
  | CollectionEntry<"projects">
  | CollectionEntry<"wiki">;

export async function getStaticPaths() {
  // Turn a permalink into a catch-all slug: strip surrounding slashes so
  // `/` → undefined (the home index) and `/platsec/blime` → "platsec/blime".
  // `build.format: "directory"` + `trailingSlash: "always"` then emits every
  // page as `slug/index.html` (served at a trailing-slash URL). Defined inside
  // getStaticPaths — Astro evaluates it in an isolated chunk, so module-scope
  // helpers it references can be tree-shaken away. Plain string ops (no regex)
  // per repo convention.
  function toSlug(permalink: string): string | undefined {
    let s = permalink;
    while (s.startsWith("/")) s = s.slice(1);
    while (s.endsWith("/")) s = s.slice(0, -1);
    return s === "" ? undefined : s;
  }

  const pages = await getCollection("pages");
  const projects = await getCollection("projects");
  const wiki = await getCollection("wiki");

  // pages/projects carry an explicit permalink; wiki permalinks are derived
  // from the file path (src/lib/wiki.ts). `published: false` (the contributor
  // template) is skipped, preserving the live 404 at its permalink.
  const built: { permalink: string; entry: ContentEntry }[] = [
    ...[...pages, ...projects]
      .filter((entry) => entry.data.published !== false)
      .map((entry) => ({ permalink: entry.data.permalink, entry })),
    ...wiki.map((entry) => ({ permalink: wikiPermalink(entry.id), entry })),
  ];

  return built.map(({ permalink, entry }) => ({
    params: { slug: toSlug(permalink) },
    props: { entry },
  }));
}

interface Props {
  entry: ContentEntry;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const isWiki = entry.collection === "wiki";
// Only `pages` carry a permalink; home is the page whose permalink is "/".
const isHome = entry.collection === "pages" && entry.data.permalink === "/";

// Header model by page role:
//   home          → site title + subtitle
//   pages         → page title + description
//   projects/wiki → no header; the body supplies its own `# Title`
let header: { title: string; subtitle?: string; description?: string } | null =
  null;
if (entry.collection === "pages") {
  header = isHome
    ? { title: SITE.name, subtitle: entry.data.subtitle }
    : { title: entry.data.title, description: entry.data.description };
}

// Wiki pages carry no `permalink`/`title`, so derive the <title> from
// frontmatter title / first H1 / path. Home passes no title prop, so <title>
// is just "Secure Systems Group".
const documentTitle = isWiki
  ? wikiTitle(entry.data, entry.body, entry.id)
  : isHome
    ? undefined
    : entry.data.title;
// `description` exists on pages and wiki, not projects.
const metaDescription =
  entry.collection === "wiki" || entry.collection === "pages"
    ? entry.data.description
    : undefined;
---

<BaseLayout title={documentTitle} description={metaDescription}>
  {
    header && (
      <header class="post-header">
        <h1 class="post-title">{header.title}</h1>
        {header.subtitle && <p class="desc" set:html={header.subtitle} />}
        {header.description && (
          <p class="post-description">{header.description}</p>
        )}
      </header>
    )
  }

  <article>
    <Content components={{ Publications }} />
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: var(--space-5);
  }

  /* .post-title is an <h1> — base.css already sizes it (40 / 300, live). */

  /* page-layout subtitle (e.g. "Machine Learning Security and Privacy"):
     0.875rem with a generous bottom gap. */
  .post-description {
    margin-top: 0;
    margin-bottom: var(--space-6);
    font-size: var(--font-size-sm);
  }

  /* about (`/`) subtitle — the three university links. .desc is left unstyled,
     so its links inherit the global theme colour. */
  .desc {
    margin-bottom: var(--space-5);
  }
</style>
