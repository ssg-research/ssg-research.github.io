---
import "./Footer.css";
import { SITE } from "../constants/site";

// Build-time copyright year (matches the live site's `site.time | date: '%Y'`).
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <p class="footer-copy">
      © Copyright {year}
      {SITE.name}. Built with <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer">Astro</a
      >, hosted on <a
        href="https://pages.github.com"
        target="_blank"
        rel="noopener noreferrer">GitHub Pages</a
      >.
    </p>
  </div>
</footer>
