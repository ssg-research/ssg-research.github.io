---
import "./Masthead.css";
import { getCollection } from "astro:content";
import ThemeToggle from "./ThemeToggle.astro";
import { SITE, HOME_NAV, BLOG_NAV, type NavItem } from "../constants/site";

// Normalize a pathname for active-link comparison: drop a trailing slash
// except on the root. Plain string ops (no regex) per repo convention.
function normalizePath(path: string): string {
  return path !== "/" && path.endsWith("/") ? path.slice(0, -1) : path;
}

const current = normalizePath(Astro.url.pathname);

// The brand is hidden on the home page (the `/` permalink); it shows on every
// other page.
const isHome = current === "/";

// Section links come from the `pages` collection (nav: true), ordered by
// nav_order; About and the external Blog link frame them (see site.ts).
const navPages: NavItem[] = (await getCollection("pages"))
  .filter((page) => page.data.nav)
  .sort((a, b) => (a.data.nav_order ?? 0) - (b.data.nav_order ?? 0))
  .map((page) => ({ title: page.data.title, href: page.data.permalink }));

const items = [HOME_NAV, BLOG_NAV, ...navPages].map((item) => ({
  ...item,
  active: !item.external && normalizePath(item.href) === current,
}));

// External links open in a new tab with a safe rel; internal links get none.
function linkAttrs(item: (typeof items)[number]) {
  return item.external ? { target: "_blank", rel: "noopener noreferrer" } : {};
}
---

<header class="masthead">
  <div class="masthead-inner">
    {
      isHome ? null : (
        <a href="/" class="masthead-brand">
          {SITE.name}
        </a>
      )
    }

    <div class="masthead-right">
      <nav class="masthead-nav" aria-label="Primary">
        {
          items.map((item) => (
            <a
              href={item.href}
              class={`nav-link ${item.active ? "active" : ""}`}
              aria-current={item.active ? "page" : undefined}
              {...linkAttrs(item)}
            >
              {item.title}
            </a>
          ))
        }
      </nav>

      <ThemeToggle />

      <details class="masthead-menu">
        <summary class="menu-summary">
          <span class="menu-label">Menu</span>
          <span class="menu-close">×</span>
        </summary>

        <nav class="menu-panel" aria-label="Primary (mobile)">
          {
            items.map((item) => (
              <a
                href={item.href}
                class={`nav-link ${item.active ? "active" : ""}`}
                aria-current={item.active ? "page" : undefined}
                {...linkAttrs(item)}
              >
                {item.title}
              </a>
            ))
          }
        </nav>
      </details>
    </div>
  </div>
</header>
